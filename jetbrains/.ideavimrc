"" Source your .vimrc

source ~/.vimrc
let mapleader = " " " map leader to Space

set idearefactormode=keep
""" Plugins ----
set NERDTree
set easymotion


" Do incremental searching.
set incsearch
set sneak
set rnu
set smartcase
set multiple-cursors
Plug 'machakann/vim-highlightedyank'



""" My Mappings -----------------

map Q gq
unmap <C-R>

map <leader>f <Plug>(easymotion-s)
map <leader>e <Plug>(easymotion-f)


""" IDEA Vim Mappins ----
map <leader>r <Action>(RenameElement)
map <leader>z <Action>(ToggleDistractionFreeMode)

map gb <Action>(Back)
nmap gf <Action>(Forward)

nmap gL <Action>(QuickImplementations)
nmap gu <Action>(GotoImplementation)
nmap gi <Action>(GotoImplementation)
nmap gI <Action>(GotoSuperMethod)
nmap gD <Action>(GotoTypeDeclaration)
nmap ge <Action>(ShowErrorDescription)
nmap gh :action QuickJavaDoc<cr>
nmap gne <Action>(GotoNextError)
nmap gpe <Action>(GotoPreviousError)


nmap <leader>c <Action>(CallHierarchy)
noremap <Leader><Leader> :action SearchEverywhere<CR>

"" Multi cursours
map mc <A-n>
map mx <A-x>
map mp <A-p>

"" Visual Mappings

vmap <A-j> <Action>(EditorSelectWord)
vmap <A-k> <Action>(EditorUnSelectWord)


nnoremap <Tab> >>_
nnoremap <S-Tab> <<_
inoremap <S-Tab> <C-D>
vnoremap <Tab> >gv
vnoremap <S-Tab> <gv

"" Movement

nmap s <Action>(AceTargetAction)

"" Bookmarks
nnoremap <leader>b :action ShowBookmarks<CR>
nnoremap mb :action ToggleBookmark<CR>

"" Bookmarks (Harpooon)
nmap <leader>h <Action>(ShowHarpoon)
nmap <leader>1 <Action>(GotoHarpoon1)
nmap <leader>2 <Action>(GotoHarpoon2)
nmap <leader>3 <Action>(GotoHarpoon3)
nmap <leader>4 <Action>(GotoHarpoon4)
nmap <leader>5 <Action>(GotoHarpoon5)
nmap h1 <Action>(SetHarpoon1)
nmap h2 <Action>(SetHarpoon2)
nmap h3 <Action>(SetHarpoon3)
nmap h4 <Action>(SetHarpoon4)
nmap h5 <Action>(SetHarpoon5)

"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"map \r <Action>(ReformatCode)

"" Map <leader>d to start debug

"" Map \b to toggle the breakpoint on the current line
map \b <Action>(ToggleLineBreakpoint)
map \d <Action>(Debug)
